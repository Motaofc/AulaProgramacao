@model a14468_employes_management.Models.Instrument

<h1>Editar Instrumento</h1>

<form asp-action="Edit">

    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label>Tipo Instrumento</label>
        <input asp-for="TipoInstrumento" class="form-control" />
    </div>

    <div class="form-group">
        <label>Nome Instrumento</label>
        <input asp-for="NomeInstrumento" class="form-control" />
    </div>

    <div class="form-group">
        <label>Usa Cordas</label>
        <input asp-for="UsaCordas" />
    </div>

    <button type="submit" class="btn btn-success">
        Guardar
    </button>

</form>